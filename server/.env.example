# Copia este archivo a .env y rellena con tus valores reales.

# --- SMTP Gmail ---
SMTP_HOST=smtp.gmail.com
# Usa 587 con SMTP_MODE=tls  (recomendado)
# o    465 con SMTP_MODE=ssl
SMTP_PORT=587
SMTP_MODE=tls

SMTP_USER=rladron@gmail.com
# Contraseña de aplicación (App Password) generada en
# https://myaccount.google.com/apppasswords  (16 caracteres sin espacios)
SMTP_PASSWORD=xxxx xxxx xxxx xxxx

# --- Correo ---
MAIL_FROM=rladron@gmail.com
MAIL_TO=rodrigo.ladron@monou.gg

# --- Servidor ---
PORT=5000
ALLOWED_ORIGIN=*
# En producción restringe a tus dominios reales, ej:
# ALLOWED_ORIGIN=https://monou.gg,https://www.monou.gg
