# Copia este archivo a .env y rellena con tus valores reales.

# --- Email (Resend, https://resend.com) ---
# Genera la API key en https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxx

# Remitente. Sin dominio verificado debes usar onboarding@resend.dev:
MAIL_FROM=Monou.gg Landing <onboarding@resend.dev>
# Con dominio verificado (https://resend.com/domains) puedes usar el tuyo:
# MAIL_FROM=Monou.gg <contacto@monou.gg>

# Destinatario(s) separados por coma. En plan free de Resend SIN dominio
# verificado, debe ser el email con el que registraste tu cuenta de Resend.
MAIL_TO=rodrigo.ladron@gmail.com
# En producción con dominio verificado, lo que prefieras:
# MAIL_TO=contacto@monou.gg,rodrigo.ladron@monou.gg

# --- Servidor ---
PORT=5000
ALLOWED_ORIGIN=*
# En producción restringe a tus dominios reales, ej:
# ALLOWED_ORIGIN=https://monou.gg,https://www.monou.gg

# --- Base de datos (opcional en local; obligatoria en Render) ---
# Si la dejas vacía, el backend funciona pero no guarda contactos en Postgres.
# Render inyecta esta variable automáticamente vía render.yaml.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- Acceso al endpoint /api/contacts (lista los contactos guardados) ---
# Genera uno con: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# ADMIN_TOKEN=tu-token-secreto-aqui
